## 1. Entidades Principales

```mermaid
classDiagram
    class Loan {
        <<entity>>
        -id: LoanIdVO
        -customerId: CustomerIdVO
        -originalCapital: MoneyVO
        -interestRate: InterestRateVO
        -startDate: DateVO
        -dueDate: DateVO
        -createdAt: DateVO
        -status: LoanStatus
        -paidInterest: MoneyVO
        -paidCapital: MoneyVO
        -capital: MoneyVO
        -remainingDebt: MoneyVO
        -nextPaymentDate: DateVO
        +create() Loan
        +reconstitute() Loan
        +makePayment() Loan
        +isInDefault() bool
        +calculateCurrentInterest() MoneyVO
        +getId() LoanIdVO
        +getCustomerId() CustomerIdVO
        +getOriginalCapital() MoneyVO
        +getCapital() MoneyVO
        +getRemainingDebt() MoneyVO
        +getInterestRate() InterestRateVO
        +getStartDate() DateVO
        +getDueDate() DateVO
        +getCreatedAt() DateVO
        +getStatus() LoanStatus
        +getPaidInterest() MoneyVO
        +getPaidCapital() MoneyVO
        +getNextPaymentDate() DateVO
    }

    class Payment {
        <<entity>>
        -id: PaymentIdVO
        -loanId: LoanIdVO
        -amount: MoneyVO
        -interestPortion: MoneyVO
        -capitalPortion: MoneyVO
        -paymentDate: DateVO
        -status: PaymentStatus
        +create() Payment
        +reconstitute() Payment
        +validate() void
        +getId() PaymentIdVO
        +getLoanId() LoanIdVO
        +getAmount() MoneyVO
        +getInterestPortion() MoneyVO
        +getCapitalPortion() MoneyVO
        +getPaymentDate() DateVO
        +getStatus() PaymentStatus
    }

    class Customer {
        <<entity>>
        -id: CustomerIdVO
        -name: NameVO
        -dni: DniVO
        -phone: PhoneVO
        -email: EmailVO
        -address: AddressVO
        +create() Customer
        +reconstitute() Customer
        +updateName() Customer
        +enable() void
        +disable() void
    }

    Loan --> CustomerIdVO : uses
    Payment --> LoanIdVO : uses
    Payment --> MoneyVO : uses
    Loan --> MoneyVO : uses
```

