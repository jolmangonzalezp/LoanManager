## 2. Value Objects

```mermaid
classDiagram
    class MoneyVO {
        <<value object>>
        -amount: int
        -currency: Currency
        +create(int, string) MoneyVO
        +zero(string) MoneyVO
        +getAmount() int
        +getCurrency() Currency
        +add(MoneyVO) MoneyVO
        +subtract(MoneyVO) MoneyVO
        +multiply(float) MoneyVO
        +isZero() bool
        +isPositive() bool
    }

    class DateVO {
        <<value object>>
        -date: DateTime
        +create(string) DateVO
        +now() DateVO
        +addMonths(int) DateVO
        +diffInMonths(DateVO) int
        +getFormatted() string
        +isFuture() bool
        +isPast() bool
    }

    class InterestRateVO {
        <<value object>>
        -annualRate: float
        -monthlyRate: float
        +createAnnual(float) InterestRateVO
        +createMonthly(float) InterestRateVO
        +calculateInterest(MoneyVO) MoneyVO
        +getAnnualRate() float
        +getMonthlyRate() float
    }

    class NameVO {
        <<value object>>
        -firstName: string
        -lastName: string
        +create(string, string) NameVO
        +getFirstName() string
        +getLastName() string
        +fullName() string
    }

    class DniVO {
        <<value object>>
        -type: DniType
        -number: string
        +create(string, string) DniVO
        +getType() DniType
        +getNumber() string
        +formatted() string
    }

    class LoanStatus {
        <<enum>>
        +ACTIVE
        +PAID
        +DEFAULTED
        +CANCELLED
    }

    class PaymentStatus {
        <<enum>>
        +PENDING
        +VALIDATED
        +APPLIED
        +REJECTED
    }
```

