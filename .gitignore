# -----------------------------
# Laravel core
# -----------------------------
/vendor
/node_modules
/storage/*.key
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*

# -----------------------------
# Environment
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# Build frontend (IMPORTANTE)
# -----------------------------
# ❌ NO ignores esto si haces build local
# 👉 necesitas subirlo para producción estable
# /public/build   ← NO ignorar

# -----------------------------
# Vite / frontend
# -----------------------------
/node_modules
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# IDE / OS
# -----------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------
# Testing
# -----------------------------
/phpunit.result.cache

# -----------------------------
# Composer
# -----------------------------
/composer.lock
# 👉 OPCIONAL:
# si trabajas en equipo, NO ignores composer.lock

# -----------------------------
# Docker (si luego usas)
/docker-compose.override.yml

# -----------------------------
# Misc
# -----------------------------
*.log
*.cache
*.tmp
